pipeline {
    agent any

    environment {
        SONARQUBE_ENV = 'sonar'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'aziz-aroua',
                url: 'https://github.com/rouamenaa/Esprit-PIDEV-4SAE8-2026-SmartFreelance.git'
            }
        }

        stage('Build') {
            steps {
                echo 'Building project...'
                sh '''
                    cd smartfreelance-backend/formation-certification-service
                    mvn clean package -DskipTests
                '''
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
                sh '''
                    cd smartfreelance-backend/formation-certification-service
                    mvn test
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo 'Running SonarQube analysis...'
                withSonarQubeEnv("${SONARQUBE_ENV}") {
                    sh '''
                        cd smartfreelance-backend/formation-certification-service
                        mvn sonar:sonar
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
            build job: 'CD-Pipeline', parameters: [string(name: 'IMAGE_TAG', value: "${BUILD_NUMBER}")]
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}