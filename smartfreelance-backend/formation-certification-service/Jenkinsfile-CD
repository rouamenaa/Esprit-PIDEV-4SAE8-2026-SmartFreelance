pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag')
    }

    environment {
        DOCKER_REPO = 'azizaroua/formation-service'
        APP_PATH = 'smartfreelance-backend/formation-certification-service'
    }

    stages {

        stage('Docker Build') {
            steps {
                script {
                    echo "Building Docker image: ${DOCKER_REPO}:${params.IMAGE_TAG}"
                    sh "docker build -t ${DOCKER_REPO}:${params.IMAGE_TAG} ${APP_PATH}"
                }
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    echo "Pushing image..."
                    sh "docker push ${DOCKER_REPO}:${params.IMAGE_TAG}"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    echo "Deploying version ${params.IMAGE_TAG}"

                    sh """
                        sed -i 's/IMAGE_TAG/${params.IMAGE_TAG}/g' ${APP_PATH}/k8s/deployment.yaml
                        kubectl apply -f ${APP_PATH}/k8s/deployment.yaml
                        kubectl apply -f ${APP_PATH}/k8s/service.yaml
                    """
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                sh "kubectl get pods"
                sh "kubectl get services"
            }
        }
    }

    post {
        always {
            sh "git checkout ${APP_PATH}/k8s/deployment.yaml || true"
        }
        success {
            echo "Deployment successful!"
        }
        failure {
            echo "Deployment failed!"
        }
    }
}
